            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Student\",\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"student\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "response": []
