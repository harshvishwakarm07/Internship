              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"feedback\": \"Good progress. Keep improving docs quality.\",\n  \"status\": \"Reviewed\",\n  \"rating\": 4\n}"
            },
            "url": "{{baseUrl}}/reports/{{reportId}}/feedback"
