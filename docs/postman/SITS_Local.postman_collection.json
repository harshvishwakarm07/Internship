    {
      "name": "Student",
      "item": [
        {
          "name": "Create Internship",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data._id) pm.environment.set('internshipId', data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "companyName", "value": "Acme Corp", "type": "text" },
                { "key": "role", "value": "Frontend Intern", "type": "text" },
                { "key": "startDate", "value": "2026-04-01", "type": "text" },
                { "key": "endDate", "value": "2026-09-30", "type": "text" },
                { "key": "offerLetter", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/internships"
          },
          "response": []
        },
        {
          "name": "Get My Internships",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "url": "{{baseUrl}}/internships/my"
          },
          "response": []
        },
        {
          "name": "Submit Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data._id) pm.environment.set('reportId', data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "internship", "value": "{{internshipId}}", "type": "text" },
                { "key": "weekNumber", "value": "1", "type": "text" },
                { "key": "content", "value": "Completed week 1 implementation and documentation tasks.", "type": "text" },
                { "key": "attachment", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/reports"
          },
          "response": []
        },
        {
          "name": "Upload Certificate",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "certificate", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/internships/{{internshipId}}/certificate"
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "url": "{{baseUrl}}/profile"
          },
          "response": []
        }
      ]
    },
